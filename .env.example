# Turso (required for all database-backed API routes)
TURSO_DATABASE_URL=libsql://your-db-name-username.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Vercel Blob (required for /api/v1/uploads/cover)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Optional: Firebase Admin (for future /api/v1/* auth endpoints)
# Option A: full service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: individual fields instead of FIREBASE_SERVICE_ACCOUNT_JSON
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: used in landing page text
NEXT_PUBLIC_APP_NAME=BlackPirateX Book Tracker
